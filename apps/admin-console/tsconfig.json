{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",

    /* ------------------------------------------------------------------
     * 开发期路径映射：覆盖 SvelteKit 生成的 paths，将 @h-ai/* 指向 src 源码
     * 同时保留 SvelteKit 生成的 $lib / $components 等别名
     * ------------------------------------------------------------------ */
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "$components": ["./src/lib/components"],
      "$components/*": ["./src/lib/components/*"],
      "$stores": ["./src/lib/stores"],
      "$stores/*": ["./src/lib/stores/*"],
      "$utils": ["./src/lib/utils"],
      "$utils/*": ["./src/lib/utils/*"],
      "$app/types": ["./.svelte-kit/types/index.d.ts"],
      "@h-ai/core": ["../../packages/core/src/index.ts"],
      "@h-ai/ai": ["../../packages/ai/src/index.ts"],
      "@h-ai/ai/client": ["../../packages/ai/src/client/index.ts"],
      "@h-ai/cache": ["../../packages/cache/src/index.ts"],
      "@h-ai/crypto": ["../../packages/crypto/src/index.ts"],
      "@h-ai/db": ["../../packages/db/src/index.ts"],
      "@h-ai/iam": ["../../packages/iam/src/index.ts"],
      "@h-ai/iam/client": ["../../packages/iam/src/client/index.ts"],
      "@h-ai/kit": ["../../packages/kit/src/index.ts"],
      "@h-ai/kit/client": ["../../packages/kit/src/client/index.ts"],
      "@h-ai/kit/crypto": ["../../packages/kit/src/modules/crypto/index.ts"],
      "@h-ai/reach": ["../../packages/reach/src/index.ts"],
      "@h-ai/storage": ["../../packages/storage/src/index.ts"],
      "@h-ai/storage/client": ["../../packages/storage/src/client/index.ts"],
      "@h-ai/ui": ["../../packages/ui/src/lib/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/**/*",
    "src/**/*.svelte"
  ],
  "exclude": [
    "node_modules",
    ".svelte-kit"
  ]
}
