{
    "extends": "./.svelte-kit/tsconfig.json",
    "compilerOptions": {
        "strict": true,
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true
    },
    "include": [
        "src/**/*",
        "src/**/*.svelte"
    ],
    "exclude": [
        "node_modules",
        ".svelte-kit"
    ]
}