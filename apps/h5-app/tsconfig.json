{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",

    /* 开发期路径映射：让 IDE "Go to Definition" 导航到 src 源码 */
    "paths": {
      "$app/types": ["./.svelte-kit/types/index.d.ts"],
      "@h-ai/core": ["../../packages/core/src/index.ts"],
      "@h-ai/kit": ["../../packages/kit/src/index.ts"],
      "@h-ai/kit/client": ["../../packages/kit/src/client/index.ts"],
      "@h-ai/kit/crypto": ["../../packages/kit/src/modules/crypto/index.ts"],
      "@h-ai/ui": ["../../packages/ui/src/lib/index.ts"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
