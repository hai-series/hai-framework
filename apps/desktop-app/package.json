{
  "name": "desktop-app",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "hai Agent Framework - 桌面应用（Tauri v2 + SvelteKit SPA）",
  "keywords": [
    "hai",
    "desktop",
    "tauri",
    "sveltekit",
    "svelte5"
  ],
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "dev": "vite dev --port 5176",
    "build": "vite build",
    "preview": "vite preview --port 5176",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rimraf .svelte-kit build .turbo",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@h-ai/api-client": "workspace:*",
    "@h-ai/core": "workspace:*",
    "@h-ai/iam": "workspace:*",
    "@h-ai/ui": "workspace:*",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-shell": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@iconify-json/tabler": "catalog:",
    "@iconify/tailwind4": "catalog:",
    "@inlang/paraglide-js": "catalog:",
    "@inlang/plugin-message-format": "catalog:",
    "@playwright/test": "catalog:",
    "@sveltejs/adapter-static": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/node": "catalog:",
    "daisyui": "catalog:",
    "rimraf": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
