{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "paraglide:compile": {
      "dependsOn": [],
      "outputs": [
        "src/lib/paraglide/**",
        "src/i18n/paraglide/**"
      ],
      "inputs": [
        "project.inlang/**",
        "messages/**"
      ],
      "cache": true
    },
    "build": {
      "dependsOn": [
        "^build",
        "paraglide:compile"
      ],
      "outputs": [
        "dist/**",
        ".svelte-kit/**"
      ],
      "cache": true
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "cache": true
    },
    "lint:fix": {
      "dependsOn": [],
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
