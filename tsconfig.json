{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* ------------------------------------------------------------------ */
    /* 开发期路径映射：让 IDE "Go to Definition" 直接导航到 src 源码       */
    /* 仅影响 TS Language Server，不影响 tsup / vite 等构建工具的模块解析   */
    /* ------------------------------------------------------------------ */
    "paths": {
      "@h-ai/core": ["./packages/core/src/index.ts"],
      "@h-ai/ai": ["./packages/ai/src/index.ts"],
      "@h-ai/ai/client": ["./packages/ai/src/client/index.ts"],
      "@h-ai/cache": ["./packages/cache/src/index.ts"],
      "@h-ai/cli": ["./packages/cli/src/index.ts"],
      "@h-ai/crypto": ["./packages/crypto/src/index.ts"],
      "@h-ai/db": ["./packages/db/src/index.ts"],
      "@h-ai/reldb": ["./packages/reldb/src/index.ts"],
      "@h-ai/vecdb": ["./packages/vecdb/src/index.ts"],
      "@h-ai/datapipe": ["./packages/datapipe/src/index.ts"],
      "@h-ai/deploy": ["./packages/deploy/src/index.ts"],
      "@h-ai/iam": ["./packages/iam/src/index.ts"],
      "@h-ai/kit": ["./packages/kit/src/index.ts"],
      "@h-ai/kit/client": ["./packages/kit/src/client/index.ts"],
      "@h-ai/kit/crypto": ["./packages/kit/src/modules/crypto/index.ts"],
      "@h-ai/reach": ["./packages/reach/src/index.ts"],
      "@h-ai/scheduler": ["./packages/scheduler/src/index.ts"],
      "@h-ai/storage": ["./packages/storage/src/index.ts"],
      "@h-ai/storage/client": ["./packages/storage/src/client/index.ts"],
      "@h-ai/storage/api": ["./packages/storage/src/api/index.ts"],
      "@h-ai/ai/api": ["./packages/ai/src/api/index.ts"],
      "@h-ai/iam/api": ["./packages/iam/src/api/index.ts"],
      "@h-ai/payment": ["./packages/payment/src/index.ts"],
      "@h-ai/payment/api": ["./packages/payment/src/api/index.ts"],
      "@h-ai/ui": ["./packages/ui/src/lib/index.ts"]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "strict": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    ".turbo",
    ".svelte-kit"
  ]
}
