# =============================================================================
# hai-framework unified environment variables (workspace-level)
# =============================================================================
# Copy this file to .env and fill real values for your local/dev environment.
# Naming convention: HAI_<MODULE>_<SETTING>
# =============================================================================

# --- Core / runtime ---
HAI_ENV=development
HAI_DEBUG=false
# HAI_APP_NAME=my-app
# HAI_LOG_LEVEL=info
# HAI_LOG_FORMAT=pretty

# --- Database (reldb) ---
HAI_DB_TYPE=sqlite
HAI_DB_DATABASE=./data/app.db
# HAI_DB_HOST=localhost
# HAI_DB_PORT=5432
# HAI_DB_USER=postgres
# HAI_DB_PASSWORD=
# Optional unified DSN (some deploy workflows output this)
# HAI_DB_URL=

# --- Cache (cache) ---
HAI_CACHE_TYPE=memory
# HAI_CACHE_REDIS_URL=redis://localhost:6379/0
# HAI_CACHE_REDIS_HOST=localhost
# HAI_CACHE_REDIS_PORT=6379
# HAI_CACHE_REDIS_PASSWORD=
# HAI_CACHE_REDIS_DB=0
# HAI_CACHE_CONNECT_TIMEOUT=10000
# HAI_CACHE_COMMAND_TIMEOUT=5000
# HAI_CACHE_KEY_PREFIX=hai:
# Deploy-generated Upstash style vars
# HAI_CACHE_UPSTASH_URL=
# HAI_CACHE_UPSTASH_TOKEN=

# --- Session / Auth (iam + kit) ---
HAI_SESSION_SECRET=change-me-to-a-strong-random-string-min-32-chars
# HAI_COOKIE_KEY=change-me-cookie-encryption-key
# HAI_IAM_PASSWORD_MIN_LENGTH=8
# HAI_IAM_SESSION_MAX_AGE=86400
# HAI_IAM_REFRESH_TOKEN_MAX_AGE=604800
# HAI_IAM_MAX_LOGIN_ATTEMPTS=5

# --- Storage (storage) ---
HAI_STORAGE_TYPE=local
HAI_STORAGE_PATH=./data/uploads
# HAI_STORAGE_S3_BUCKET=
# HAI_STORAGE_S3_REGION=us-east-1
# HAI_STORAGE_S3_ACCESS_KEY=
# HAI_STORAGE_S3_SECRET_KEY=
# HAI_STORAGE_S3_ENDPOINT=
# HAI_STORAGE_S3_FORCE_PATH_STYLE=false

# --- AI (ai) ---
# Prefer HAI_OPENAI_* keys; OPENAI_* remains as compatibility fallback in ai-config.
# HAI_OPENAI_API_KEY=
# HAI_OPENAI_BASE_URL=https://api.openai.com/v1
# HAI_AI_MODEL=gpt-4o-mini
# HAI_AI_API_KEY=
# HAI_AI_BASE_URL=
# HAI_ANTHROPIC_API_KEY=
# Optional compatibility fallbacks
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Vector DB (vecdb) ---
# HAI_VECDB_TYPE=lancedb
# HAI_VECDB_PATH=./data/vecdb
# HAI_VECDB_PG_URL=postgres://user:pass@localhost:5432/mydb
# HAI_VECDB_QDRANT_URL=http://localhost:6333
# HAI_VECDB_QDRANT_API_KEY=

# --- Reach (reach) ---
# HAI_REACH_SMTP_HOST=smtp.example.com
# HAI_REACH_SMTP_PORT=465
# HAI_REACH_SMTP_USER=
# HAI_REACH_SMTP_PASS=
# HAI_REACH_SMTP_FROM=noreply@example.com
# HAI_REACH_SMS_ACCESS_KEY=
# HAI_REACH_SMS_SECRET_KEY=
# HAI_REACH_SMS_SIGN_NAME=
# HAI_REACH_WEBHOOK_URL=

# --- Payment (payment) ---
# HAI_PAY_WECHAT_APP_ID=
# HAI_PAY_WECHAT_MCH_ID=
# HAI_PAY_WECHAT_API_V3_KEY=
# HAI_PAY_WECHAT_PRIVATE_KEY=
# HAI_PAY_WECHAT_SERIAL_NO=
# HAI_PAY_WECHAT_NOTIFY_URL=
# HAI_PAY_ALIPAY_APP_ID=
# HAI_PAY_ALIPAY_PRIVATE_KEY=
# HAI_PAY_ALIPAY_PUBLIC_KEY=
# HAI_PAY_ALIPAY_NOTIFY_URL=
# HAI_PAY_STRIPE_SECRET_KEY=
# HAI_PAY_STRIPE_WEBHOOK_SECRET=
# HAI_PAY_STRIPE_SUCCESS_URL=
# HAI_PAY_STRIPE_CANCEL_URL=

# --- Deploy credentials (deploy / CLI) ---
# HAI_DEPLOY_VERCEL_TOKEN=
# HAI_DEPLOY_NEON_API_KEY=
# HAI_DEPLOY_UPSTASH_EMAIL=
# HAI_DEPLOY_UPSTASH_API_KEY=
# HAI_DEPLOY_CF_ACCOUNT_ID=
# HAI_DEPLOY_CF_API_TOKEN=
# HAI_DEPLOY_RESEND_API_KEY=
# HAI_DEPLOY_ALIYUN_ACCESS_KEY_ID=
# HAI_DEPLOY_ALIYUN_ACCESS_KEY_SECRET=

# --- App-specific vars ---
# HAI_PARTNER_ADMIN_USERNAME=partner-admin
# HAI_PARTNER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# HAI_PARTNER_SESSION_TTL=14400
# HAI_CRYPTO_DATA_KEY=

# --- Dev/test helpers ---
# HAI_E2E=1
# BASE_URL=http://localhost:4173
# PUBLIC_API_BASE=http://10.0.2.2:5173
# VITE_ADAPTER=node
# CI=0
