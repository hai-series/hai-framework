# =============================================================================
# hai-framework - 根目录环境变量模板
# =============================================================================
#
# 将此文件复制为 .env 并填入实际值。
# 各应用可在自己目录下有独立的 .env（会覆盖根目录的值）。
#
# =============================================================================

# 应用环境
HAI_ENV=development
HAI_DEBUG=false
HAI_LOG_LEVEL=info
HAI_LOG_FORMAT=logfmt

# 数据库
HAI_DB_TYPE=sqlite
HAI_DB_DATABASE=./data/app.db

# 会话密钥（至少 32 个字符）
HAI_SESSION_SECRET=change-me-to-a-strong-random-string-min-32-chars

# 缓存
HAI_CACHE_TYPE=memory
# HAI_CACHE_REDIS_URL=redis://localhost:6379

# 存储
HAI_STORAGE_TYPE=local
# HAI_STORAGE_S3_BUCKET=
# HAI_STORAGE_S3_REGION=us-east-1
# HAI_STORAGE_S3_ACCESS_KEY=
# HAI_STORAGE_S3_SECRET_KEY=

# AI（按需启用）
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
