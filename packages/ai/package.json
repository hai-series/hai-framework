{
    "name": "@hai/ai",
    "version": "0.1.0",
    "description": "hai Admin Framework - AI 模块（LLM 适配器、流式响应、工具调用）",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./adapter": {
            "types": "./dist/adapter.d.ts",
            "import": "./dist/adapter.js"
        },
        "./stream": {
            "types": "./dist/stream.d.ts",
            "import": "./dist/stream.js"
        },
        "./tools": {
            "types": "./dist/tools.d.ts",
            "import": "./dist/tools.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@hai/core": "workspace:*",
        "@hai/config": "workspace:*",
        "openai": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "zod": "catalog:"
    }
}