{
  "name": "@hai/cli",
  "type": "module",
  "version": "0.1.0",
  "description": "hai Admin Framework CLI - 项目脚手架和代码生成器",
  "license": "Apache-2.0",
  "keywords": [
    "hai",
    "cli",
    "scaffold",
    "generator"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hai": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@hai/core": "workspace:*",
    "cac": "catalog:",
    "chalk": "catalog:",
    "fs-extra": "catalog:",
    "handlebars": "catalog:",
    "ora": "catalog:",
    "prompts": "catalog:"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@types/prompts": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
