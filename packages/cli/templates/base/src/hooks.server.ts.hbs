/**
 * =============================================================================
 * {{projectName}} - Server Hooks
 * =============================================================================
 */

import type { Handle } from '@sveltejs/kit'
import { initApp } from '$lib/server/init.js'
import { core } from '@h-ai/core'
import { kit } from '@h-ai/kit'
{{#if features.iam}}
import { iam } from '@h-ai/iam'
{{/if}}
{{#if features.crypto}}
import { crypto } from '@h-ai/crypto'
{{/if}}
{{#if hasI18n}}
import { paraglideMiddleware } from '$lib/paraglide/server.js'
{{/if}}

{{#if features.crypto}}
// 初始化加密模块（同步）
crypto.init()

{{/if}}
// =============================================================================
// 应用初始化
// =============================================================================

let appInitPromise: Promise<void> | null = null

async function ensureAppInitialized() {
  if (!appInitPromise) {
    appInitPromise = initApp().catch((err: unknown) => {
      appInitPromise = null
      throw err
    })
  }
  await appInitPromise
}

// =============================================================================
// 初始化 Handle
// =============================================================================

const initHandle: Handle = async ({ event, resolve }) => {
  await ensureAppInitialized()
  return resolve(event)
}

{{#if hasI18n}}
// =============================================================================
// Paraglide i18n Middleware
// =============================================================================

/**
 * i18n Handle - 使用 Paraglide middleware 处理语言
 *
 * API 请求跳过 paraglideMiddleware（不需要页面级 locale + 避免消耗 body）
 */
const i18nHandle: Handle = async ({ event, resolve }) => {
  if (event.url.pathname.startsWith('/api/')) {
    const locale = event.cookies.get('PARAGLIDE_LOCALE') ?? '{{defaultLocale}}'
    event.locals.locale = locale
    kit.i18n.setLocale(locale)
    return resolve(event)
  }

  return paraglideMiddleware(event.request, async ({ locale }) => {
    event.locals.locale = locale
    kit.i18n.setLocale(locale)
    return resolve(event, {
      transformPageChunk: ({ html }) => html.replace('%lang%', locale),
    })
  })
}

{{/if}}
// =============================================================================
// hai Handle（会话验证 + 限流 + 日志）
// =============================================================================

const haiHandle = kit.createHandle({
{{#if features.iam}}
  auth: {
    verifyToken: async (token) => {
      const result = await iam.auth.verifyToken(token)
      return result.success ? result.data : null
    },
    operations: iam.auth,
    loginUrl: '/auth/login',
    protectedPaths: ['/admin/*', '/api/*'],
    publicPaths: ['/api/auth/*', '/api/public/*', '/api/health'],
  },
{{/if}}
  rateLimit: { windowMs: 60000, maxRequests: 200 },
  logging: { logBody: false },
  onError: (error: unknown, _event) => {
    core.logger.error('Request error:', { error })
    return new Response(
      JSON.stringify({
        success: false,
        error: {
          code: 'INTERNAL_ERROR',
          message: error instanceof Error ? error.message : 'Unknown error',
        },
      }),
      { status: 500, headers: { 'Content-Type': 'application/json' } },
    )
  },
})

// =============================================================================
// 组合 Handle
// =============================================================================

export const handle = kit.sequence(
  initHandle,
{{#if hasI18n}}
  i18nHandle,
{{/if}}
  haiHandle,
)
