{
    "name": "@hai/skills",
    "version": "0.1.0",
    "description": "hai Admin Framework - Skills 模块（技能定义、注册、执行）",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@hai/core": "workspace:*",
        "@hai/ai": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "zod": "catalog:"
    }
}