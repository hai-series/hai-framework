{
  "name": "@hai/kit",
  "type": "module",
  "version": "0.1.0",
  "description": "hai Admin Framework - SvelteKit 集成",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules/iam": {
      "types": "./dist/modules/iam/index.d.ts",
      "import": "./dist/modules/iam/index.js"
    },
    "./modules/storage": {
      "types": "./dist/modules/storage/index.d.ts",
      "import": "./dist/modules/storage/index.js"
    },
    "./modules/cache": {
      "types": "./dist/modules/cache/index.d.ts",
      "import": "./dist/modules/cache/index.js"
    },
    "./modules/crypto": {
      "types": "./dist/modules/crypto/index.d.ts",
      "import": "./dist/modules/crypto/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.50.1",
    "svelte": "^5.49.11"
  },
  "dependencies": {
    "@hai/cache": "workspace:*",
    "@hai/core": "workspace:*",
    "@hai/db": "workspace:*",
    "@hai/iam": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/kit": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "svelte": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
