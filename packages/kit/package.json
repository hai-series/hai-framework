{
  "name": "@h-ai/kit",
  "type": "module",
  "version": "0.1.0",
  "description": "Hai Framework SvelteKit integration module.",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./crypto": {
      "types": "./dist/modules/crypto/index.d.ts",
      "import": "./dist/modules/crypto/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.js"
    },
    "./a2a": {
      "types": "./dist/modules/a2a/index.d.ts",
      "import": "./dist/modules/a2a/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.53.4",
    "svelte": "^5.53.6"
  },
  "peerDependenciesMeta": {
    "@sveltejs/adapter-node": { "optional": true },
    "@sveltejs/adapter-static": { "optional": true }
  },
  "dependencies": {
    "@h-ai/core": "workspace:*",
    "@h-ai/iam": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/kit": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "svelte": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
