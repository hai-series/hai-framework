{
  "name": "@h-ai/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Hai Framework core module with shared utilities, types, configuration, and logging.",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "main": "./dist/node.js",
  "browser": "./dist/browser.js",
  "types": "./dist/node.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "nanoid": "catalog:",
    "zod": "catalog:"
  },
  "optionalDependencies": {
    "loglevel": "catalog:",
    "pino": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint-plugin-format": "catalog:",
    "loglevel": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  }
}
