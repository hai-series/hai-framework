{
  "name": "@hai/core",
  "type": "module",
  "version": "0.1.0",
  "description": "hai Admin Framework - Core utilities, types and functions",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "browser": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n/paraglide",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "nanoid": "catalog:",
    "zod": "catalog:"
  },
  "optionalDependencies": {
    "loglevel": "catalog:",
    "pino": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "catalog:",
    "@types/node": "catalog:",
    "eslint-plugin-format": "catalog:",
    "loglevel": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  }
}
