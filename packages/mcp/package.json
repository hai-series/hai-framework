{
    "name": "@hai/mcp",
    "version": "0.1.0",
    "description": "hai Admin Framework - MCP 模块（Model Context Protocol）",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@hai/core": "workspace:*",
        "@modelcontextprotocol/sdk": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "zod": "catalog:"
    }
}