# =============================================================================
# hai Agent Framework - Git 忽略配置
# =============================================================================

# 依赖
node_modules/
.pnpm-store/

# 构建输出
dist/
build/
.svelte-kit/
.turbo/

# 测试覆盖率
coverage/

# 日志
*.log
logs/

# 环境变量
.env
.env.local
.env.*.local

# IDE
.idea/
*.swp
*.swo
.DS_Store

# 类型生成
*.tsbuildinfo

# 构建生成的声明文件（tsup 输出到 dist/，src/ 下的为误生成）
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# 运行时数据（SQLite 数据库、上传文件等）
data/

# 临时文件
tmp/
temp/
.cache/
.tmp-*/

data/
test-results/
test-data/
