# =============================================================================
# hai Admin Framework - NPM 配置
# =============================================================================
# pnpm 工作区配置
# =============================================================================

# 允许提升依赖到 node_modules 根目录（某些包需要）
shamefully-hoist=true

# 使用严格的对等依赖检查
strict-peer-dependencies=false

# 自动安装对等依赖
auto-install-peers=true

# 使用 node-linker
node-linker=hoisted
